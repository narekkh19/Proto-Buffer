namespace tutorial;

class Person {
  string name = 1;
  int id = 2;
  string email = 3;

  enum PhoneType {
    PHONE_TYPE_UNSPECIFIED = 0;
    PHONE_TYPE_MOBILE = 1;
    PHONE_TYPE_HOME = 2;
    PHONE_TYPE_WORK = 3;
  }

  class PhoneNumber {
    string number = 1;
    PhoneType type = 2;
  }

  vector PhoneNumber phones = 4;
}

class AddressBook {
  vector Person people = 1;
}
